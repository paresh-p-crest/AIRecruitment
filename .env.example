# =============================================================================
# SliceHRMS — local environment (minimal)
# =============================================================================
# LLM provider & AWS Bedrock credentials are configured in the app:
#   Settings → LLM Model  (saved in the database, not in this file)
#
# Do not put OPENAI_API_KEY, GOOGLE_API_KEY, or AWS secrets here unless you
# want a one-time bootstrap on first DB init (optional; Settings UI is preferred).
# =============================================================================

# Application database
DATABASE_URL=sqlite+aiosqlite:///./recruitment.db

# PDF extraction via AWS Textract (uses credentials from Settings → LLM Model)
USE_TEXTRACT=true

# Optional: LangSmith tracing
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key
# LANGCHAIN_PROJECT=ai-recruitment-demo

# Optional: Windows legacy .doc via LibreOffice (local dev only)
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe

# Optional: Linux antiword for .doc (Render/Linux servers)
# ANTIWORD_PATH=/usr/bin/antiword

# Optional: disable specific .doc parsers (see doc_converter.py)
# DISABLE_OFFICE_OXIDE=true
# DISABLE_SHAREPOINT2TEXT=true
# DISABLE_TIKA=true
# DISABLE_DOC_OLE_FALLBACK=true
