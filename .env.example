# LLM provider: aws_bedrock (default), openai, or google
# Credentials can also be configured via the Settings page in the UI.
LLM_PROVIDER=aws_bedrock

# AWS Bedrock (recommended for AWS sandbox / demo)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SESSION_TOKEN=your-session-token-if-using-sandbox-temp-creds
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# OpenAI (alternative provider)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Google AI Studio (Gemini)
GOOGLE_API_KEY=your-google-ai-studio-api-key
GOOGLE_MODEL=gemini-2.5-flash

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-api-key
LANGCHAIN_PROJECT=ai-recruitment-demo

# Application
DATABASE_URL=sqlite+aiosqlite:///./recruitment.db

# Hybrid extraction: Textract for PDF only; DOC/DOCX use local parsers
USE_TEXTRACT=true

# Legacy .doc extraction (tried in order; LibreOffice is NOT required):
# - office-oxide + sharepoint-to-text: pip deps, work on live servers without LibreOffice/Java
# - antiword on Linux: apt install antiword  (optional, fast on Linux)
# - Apache Tika: requires Java 17+ (optional fallback)
# - LibreOffice: optional local dev fallback only
# ANTIWORD_PATH=/usr/bin/antiword
# LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.exe
# DISABLE_OFFICE_OXIDE=true
# DISABLE_SHAREPOINT2TEXT=true
# DISABLE_TIKA=true
# DISABLE_DOC_OLE_FALLBACK=true
